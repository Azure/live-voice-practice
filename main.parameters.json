{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "environmentName": { "value": "${AZURE_ENV_NAME}" },
    "location": { "value": "${AZURE_LOCATION}" },
    "cosmosLocation": { "value": "${AZURE_COSMOS_LOCATION=${AZURE_LOCATION}}" },
    "searchServiceLocation": { "value": "${AZURE_SEARCH_LOCATION=swedencentral}" },
    "principalId": { "value": "${AZURE_PRINCIPAL_ID}" },
    "principalType": { "value": "${AZURE_PRINCIPAL_TYPE=User}" },
    "deploymentTags": { "value": {} },
    "appConfigLabel": { "value": "live-voice-practice" },

    "networkIsolation": { "value": "${NETWORK_ISOLATION=false}" },
    "useUAI": { "value": "${USE_UAI=false}" },
    "useCAppAPIKey": { "value": "${USE_CAPP_API_KEY=false}" },
    "useZoneRedundancy": { "value": "false" },
    "enableAgenticRetrieval": { "value": "${ENABLE_AGENTIC_RETRIEVAL=false}" },

    "deployGroundingWithBing": { "value": "false" },
    "deployAiFoundry": { "value": "true" },
    "deployAiFoundrySubnet": { "value": "false" },
    "deployAppConfig": { "value": "true" },
    "deployKeyVault": { "value": "true" },
    "deployVmKeyVault": { "value": "false" },
    "deployLogAnalytics": { "value": "true" },
    "deployAppInsights": { "value": "true" },
    "deploySearchService": { "value": "true" },
    "deployStorageAccount": { "value": "true" },
    "deployCosmosDb": { "value": "true" },
    "deployContainerApps": { "value": "true" },
    "deployContainerRegistry": { "value": "true" },
    "deployContainerEnv": { "value": "true" },
    "deployVM": { "value": "true" },
    "deploySubnets": { "value": "true" },
    "deployNsgs": { "value": "false" },
    "sideBySideDeploy": { "value": "false" },
    "deploySoftware": { "value": "true" },
    "deployAfProject": { "value": "true" },
    "deployAAfAgentSvc": { "value": "false" },

    "useExistingVNet": { "value": "${USE_EXISTING_VNET=false}" },
    "existingVnetResourceId": { "value": "${EXISTING_VNET_RESOURCE_ID=}" },

    "vmAdminPassword": { "value": "$(secretOrRandomPassword)" },
    "vmSize": { "value": "Standard_D2s_v3" },

    "extraRepoUrls": { "value": ["https://github.com/Azure/live-voice-practice.git"] },
    "extraRepoTags": { "value": ["main"] },
    "extraRepoNames": { "value": ["live-voice-practice"] },

    "modelDeploymentList": {
      "value": [
        {
          "name": "chat",
          "model": {
            "format": "OpenAI",
            "name": "gpt-4.1-mini",
            "version": "2025-04-14"
          },
          "sku": {
            "name": "GlobalStandard",
            "capacity": 50
          },
          "canonical_name": "CHAT_DEPLOYMENT_NAME",
          "apiVersion": "2025-01-01-preview"
        },
        {
          "name": "text-embedding",
          "model": {
            "format": "OpenAI",
            "name": "text-embedding-3-large",
            "version": "1"
          },
          "sku": {
            "name": "Standard",
            "capacity": 50
          },
          "canonical_name": "EMBEDDING_DEPLOYMENT_NAME",
          "apiVersion": "2025-01-01-preview"
        },
        {
          "name": "gpt-realtime",
          "model": {
            "format": "OpenAI",
            "name": "gpt-realtime-1.5",
            "version": "2026-02-23"
          },
          "sku": {
            "name": "GlobalStandard",
            "capacity": 5
          },
          "canonical_name": "REALTIME_DEPLOYMENT_NAME",
          "apiVersion": "2025-01-01-preview"
        }
      ]
    },

    "workloadProfiles": {
      "value": [
        {
          "name": "Consumption",
          "workloadProfileType": "Consumption"
        },
        {
          "workloadProfileType": "D4",
          "name": "main",
          "minimumCount": 0,
          "maximumCount": 1
        }
      ]
    },

    "storageAccountContainersList": {
      "value": [
        {
          "name": "documents",
          "canonical_name": "DOCUMENTS_STORAGE_CONTAINER"
        },
        {
          "name": "transcripts",
          "canonical_name": "TRANSCRIPTS_STORAGE_CONTAINER"
        }
      ]
    },

    "databaseContainersList": {
      "value": [
        {
          "name": "rubrics",
          "canonical_name": "RUBRICS_DATABASE_CONTAINER",
          "partitionKey": "/rubricId"
        },
        {
          "name": "scenarios",
          "canonical_name": "SCENARIOS_DATABASE_CONTAINER",
          "partitionKey": "/scenarioId"
        },
        {
          "name": "conversations",
          "canonical_name": "CONVERSATIONS_DATABASE_CONTAINER",
          "partitionKey": "/conversationId"
        },
        {
          "name": "role_assignments",
          "canonical_name": "ROLE_ASSIGNMENTS_DATABASE_CONTAINER",
          "partitionKey": "/userId"
        }
      ]
    },

    "containerAppsList": {
      "value": [
        {
          "name": null,
          "external": true,
          "service_name": "voicelab",
          "target_port": 8000,
          "profile_name": "main",
          "min_replicas": 1,
          "max_replicas": 1,
          "canonical_name": "VOICELAB_APP",
          "roles": [
            "AppConfigurationDataReader",
            "CognitiveServicesUser",
            "CognitiveServicesOpenAIUser",
            "AcrPull",
            "CosmosDBBuiltInDataContributor",
            "SearchIndexDataReader",
            "StorageBlobDataContributor",
            "KeyVaultSecretsUser"
          ]
        }
      ]
    }
  }
}
